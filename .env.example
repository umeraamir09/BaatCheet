# Convex
CONVEX_DEPLOY_KEY='preview:team:project|...'
CONVEX_URL=https://<deployment>.convex.cloud
CONVEX_SITE_URL=https://<deployment>.convex.site

# Discord OAuth (set via `bunx convex env set` for Convex backend)
# AUTH_DISCORD_ID=your-discord-client-id
# AUTH_DISCORD_SECRET=your-discord-client-secret
# AUTH_DISCORD_REDIRECT_URI=https://<deployment>.convex.site/api/auth/callback/discord
