{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-electron",
    "rootDir": "./src/main",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "noEmit": false
  },
  "include": ["src/main/**/*"],
  "exclude": ["src/main/preload.ts"]
}
