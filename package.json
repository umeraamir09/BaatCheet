{
  "name": "baatcheet",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "bun run --filter baatcheet-desktop dev",
    "dev:server": "bun run --filter baatcheet-server dev",
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run --filter './apps/*' build",
    "lint": "bun run --filter './apps/*' lint"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "trustedDependencies": [
    "baatcheet-desktop",
    "mediasoup"
  ]
}